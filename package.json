{
  "name": "juego-web",
  "version": "1.0.0",
  "description": "Juego web con Phaser 3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "security": "npm audit && lockfile-lint --path package-lock.json --type npm --allowed-hosts npm"
  },
  "dependencies": {
    "phaser": "^3.80.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "lockfile-lint": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.9"
  }
}
